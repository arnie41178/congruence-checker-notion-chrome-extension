{
  "name": "@alucify/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file .env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "test:auditor": "tsx --env-file .env src/scripts/test-auditor.ts",
    "prep:auditor": "tsx src/scripts/prep-auditor.ts",
    "phase1:prep":      "tsx src/scripts/phase1-prep.ts",
    "phase1:consensus": "tsx src/scripts/phase1-consensus.ts",
    "phase2:prep":      "tsx src/scripts/phase2-prep.ts",
    "phase3:parse":     "tsx src/scripts/phase3-parse.ts",
    "pipeline":         "tsx src/scripts/run-pipeline.ts"
  },
  "dependencies": {
    "@alucify/shared-types": "workspace:*",
    "@anthropic-ai/sdk": "^0.39.0",
    "@ladybugdb/core": "latest",
    "@upstash/redis": "^1.34.0",
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.1",
    "gitnexus": "latest",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.0",
    "tsx": "^4.10.0",
    "typescript": "^5.4.0"
  }
}
